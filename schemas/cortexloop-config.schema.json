{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeCortexLoop Config",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "preset": {
      "enum": ["default", "lite", "quick", "deep", "security", "pre-pr"]
    },
    "scope": {
      "oneOf": [
        { "enum": ["recent", "whole"], "description": "Legacy shorthand for scope mode" },
        {
          "type": "object",
          "properties": {
            "mode": { "enum": ["recent", "whole"] },
            "mapThreshold": { "type": "integer", "minimum": 1, "default": 100 },
            "smallScopeThreshold": { "type": "integer", "minimum": 1, "default": 50 },
            "deepIndexFileThreshold": { "type": "integer", "minimum": 1, "default": 300 },
            "deepIndexTopHotspots": { "type": "integer", "minimum": 1, "default": 15 },
            "hotspotSymbolHintFiles": { "type": "integer", "minimum": 1, "default": 8 },
            "deepIndexOffer": { "type": "boolean", "default": true, "description": "Ask user before Pass 1 to install/init codegraph when suggested and .codegraph missing" },
            "mapEnrichThreshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
            "longTailSampleCount": { "type": "integer", "minimum": 1, "default": 20 },
            "mapWeights": {
              "type": "object",
              "properties": {
                "churn": { "type": "number" },
                "importHub": { "type": "number" },
                "density": { "type": "number" },
                "patterns": { "type": "number" }
              }
            },
            "exclude": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "passes": {
      "type": "object",
      "properties": {
        "review": { "type": "boolean" },
        "security": { "type": "boolean" },
        "tests": { "type": "boolean" },
        "performance": { "type": "boolean" },
        "simplicity": { "type": "boolean" },
        "errorHandling": { "type": "boolean" },
        "cleanup": { "type": "boolean" }
      }
    },
    "severityFloor": {
      "enum": ["Critical", "High", "Medium", "Low", "Info"]
    },
    "direct": {
      "type": "object",
      "description": "Direct mode apply policy. fixFloor is the minimum severity tier to auto-fix (Critical always included; Info never auto-fixed). Distinct from severityFloor which filters report findings during analysis.",
      "properties": {
        "fixFloor": {
          "enum": ["High", "Medium", "Low"],
          "default": "High",
          "description": "High = Critical+High only (default); Medium = +Medium; Low = +Low"
        }
      }
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" }
    },
    "crossValidation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "requireBenchmark": { "type": "boolean" }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "depsOnly": { "type": "boolean" },
        "askBeforeDelete": { "type": "boolean" }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sarif": { "type": "boolean" },
        "autoFix": { "type": "boolean" },
        "failOnCritical": { "type": "boolean" },
        "maxHigh": { "type": "integer", "minimum": 0 },
        "outputDir": { "type": "string" },
        "baseline": { "type": "boolean" }
      }
    },
    "baseline": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "default": ".cortexloop/baseline.json" }
      }
    },
    "history": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "path": { "type": "string", "default": ".cortexloop/history.json" },
        "maxRuns": { "type": "integer", "minimum": 1, "default": 100 }
      }
    },
    "badge": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "svgPath": { "type": "string", "default": ".cortexloop/health-badge.svg" }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "htmlPath": { "type": "string", "default": "docs/cortexloop/report.html" }
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "weights": {
          "type": "object",
          "properties": {
            "correctness": { "type": "number" },
            "security": { "type": "number" },
            "performance": { "type": "number" },
            "simplicity": { "type": "number" },
            "tests": { "type": "number" },
            "errorHandling": { "type": "number" },
            "cleanup": { "type": "number" }
          }
        }
      }
    },
    "learning": {
      "type": "object",
      "description": "Learning-loop config. playbook.mjs reads these keys via loadLearningConfig(); CLI flags override them. Read keys: playbookPath (--playbook), global (--global / --global-merge), queryVerifiedOnly (--include-candidates inverts), prune.* (--min-confidence / --max-age-days / --max-entries / --drop-quarantined). enabled and reflectOn are orchestrator-level toggles (gate Step 0.5 / Step 6 in commands/cortexloop.md). Tier promotion thresholds, decay, and outcome deltas remain script-internal defaults (PLAYBOOK_DEFAULTS, OUTCOME_DELTAS in scripts/lib/shared.mjs) — NOT configurable here, because exposing them invited users to set values that previously were silently ignored.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "playbookPath": { "type": "string", "default": ".cortexloop/playbook.json" },
        "global": { "type": "boolean", "default": false },
        "reflectOn": { "enum": ["direct"], "default": "direct" },
        "queryVerifiedOnly": { "type": "boolean", "default": true, "description": "Step 0.5 surfaces only verified-tier patterns; candidates need --include-candidates (or set this false to always include candidates)" },
        "prune": {
          "type": "object",
          "properties": {
            "minConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
            "maxAgeDays": { "type": "integer", "minimum": 1, "default": 180 },
            "maxEntries": { "type": "integer", "minimum": 1, "default": 200 },
            "dropQuarantined": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
