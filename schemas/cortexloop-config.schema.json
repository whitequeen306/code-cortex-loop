{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeCortexLoop Config",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "preset": {
      "enum": ["default", "quick", "deep", "security", "pre-pr"]
    },
    "scope": {
      "oneOf": [
        { "enum": ["recent", "whole"], "description": "Legacy shorthand for scope mode" },
        {
          "type": "object",
          "properties": {
            "mode": { "enum": ["recent", "whole"] },
            "mapThreshold": { "type": "integer", "minimum": 1, "default": 100 },
            "smallScopeThreshold": { "type": "integer", "minimum": 1, "default": 50 },
            "deepIndexFileThreshold": { "type": "integer", "minimum": 1, "default": 300 },
            "deepIndexTopHotspots": { "type": "integer", "minimum": 1, "default": 15 },
            "hotspotSymbolHintFiles": { "type": "integer", "minimum": 1, "default": 8 },
            "deepIndexOffer": { "type": "boolean", "default": true, "description": "Ask user before Pass 1 to install/init codegraph when suggested and .codegraph missing" },
            "mapEnrichThreshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
            "longTailSampleCount": { "type": "integer", "minimum": 1, "default": 20 },
            "mapWeights": {
              "type": "object",
              "properties": {
                "churn": { "type": "number" },
                "importHub": { "type": "number" },
                "density": { "type": "number" },
                "patterns": { "type": "number" }
              }
            },
            "exclude": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "passes": {
      "type": "object",
      "properties": {
        "review": { "type": "boolean" },
        "security": { "type": "boolean" },
        "tests": { "type": "boolean" },
        "performance": { "type": "boolean" },
        "simplicity": { "type": "boolean" },
        "errorHandling": { "type": "boolean" },
        "cleanup": { "type": "boolean" }
      }
    },
    "severityFloor": {
      "enum": ["Critical", "High", "Medium", "Low", "Info"]
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" }
    },
    "crossValidation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "requireBenchmark": { "type": "boolean" }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "depsOnly": { "type": "boolean" },
        "askBeforeDelete": { "type": "boolean" }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sarif": { "type": "boolean" },
        "autoFix": { "type": "boolean" },
        "failOnCritical": { "type": "boolean" },
        "maxHigh": { "type": "integer", "minimum": 0 },
        "outputDir": { "type": "string" },
        "baseline": { "type": "boolean" }
      }
    },
    "baseline": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "default": ".cortexloop/baseline.json" }
      }
    },
    "history": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "path": { "type": "string", "default": ".cortexloop/history.json" },
        "maxRuns": { "type": "integer", "minimum": 1, "default": 100 }
      }
    },
    "badge": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "svgPath": { "type": "string", "default": ".cortexloop/health-badge.svg" }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "htmlPath": { "type": "string", "default": "docs/cortexloop/report.html" }
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "weights": {
          "type": "object",
          "properties": {
            "correctness": { "type": "number" },
            "security": { "type": "number" },
            "performance": { "type": "number" },
            "simplicity": { "type": "number" },
            "tests": { "type": "number" },
            "errorHandling": { "type": "number" },
            "cleanup": { "type": "number" }
          }
        }
      }
    },
    "learning": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "playbookPath": { "type": "string", "default": ".cortexloop/playbook.json" },
        "global": { "type": "boolean", "default": false },
        "reflectOn": { "enum": ["direct"], "default": "direct" },
        "queryVerifiedOnly": { "type": "boolean", "default": true, "description": "Step 0.5 surfaces only verified-tier patterns; candidates need --include-candidates" },
        "tiers": {
          "type": "object",
          "description": "Two-tier trust model thresholds (anti-hallucination)",
          "properties": {
            "newConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
            "promoteConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.7 },
            "demoteConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.4 },
            "quarantineConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2 },
            "minVerified": { "type": "integer", "minimum": 1, "default": 2 },
            "minDistinctContexts": { "type": "integer", "minimum": 1, "default": 2 }
          }
        },
        "decay": {
          "type": "object",
          "description": "Trust decays until re-validated by a verified outcome",
          "properties": {
            "perDay": { "type": "number", "minimum": 0, "default": 0.01 }
          }
        },
        "outcomeWeights": {
          "type": "object",
          "description": "Signed confidence deltas per outcome; external oracle > self-report, negatives stronger than positives",
          "properties": {
            "external_verified": { "type": "number", "default": 0.2 },
            "self_verified": { "type": "number", "default": 0.1 },
            "rejected": { "type": "number", "default": -0.1 },
            "failed": { "type": "number", "default": -0.4 }
          }
        },
        "prune": {
          "type": "object",
          "properties": {
            "minConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
            "maxAgeDays": { "type": "integer", "minimum": 1, "default": 180 },
            "maxEntries": { "type": "integer", "minimum": 1, "default": 200 },
            "dropQuarantined": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
