{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeCortexLoop Config",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "preset": {
      "enum": ["default", "quick", "deep", "security", "pre-pr"]
    },
    "scope": { "enum": ["recent", "whole"] },
    "passes": {
      "type": "object",
      "properties": {
        "review": { "type": "boolean" },
        "security": { "type": "boolean" },
        "tests": { "type": "boolean" },
        "performance": { "type": "boolean" },
        "simplicity": { "type": "boolean" },
        "errorHandling": { "type": "boolean" },
        "cleanup": { "type": "boolean" }
      }
    },
    "severityFloor": {
      "enum": ["Critical", "High", "Medium", "Low", "Info"]
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" }
    },
    "performance": {
      "type": "object",
      "properties": {
        "requireBenchmark": { "type": "boolean" }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "depsOnly": { "type": "boolean" },
        "askBeforeDelete": { "type": "boolean" }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sarif": { "type": "boolean" },
        "autoFix": { "type": "boolean" },
        "failOnCritical": { "type": "boolean" },
        "maxHigh": { "type": "integer", "minimum": 0 },
        "outputDir": { "type": "string" },
        "baseline": { "type": "boolean" }
      }
    },
    "baseline": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "default": ".cortexloop/baseline.json" }
      }
    },
    "history": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "path": { "type": "string", "default": ".cortexloop/history.json" },
        "maxRuns": { "type": "integer", "minimum": 1, "default": 100 }
      }
    },
    "badge": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "svgPath": { "type": "string", "default": ".cortexloop/health-badge.svg" }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "htmlPath": { "type": "string", "default": "docs/cortexloop/report.html" }
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "weights": {
          "type": "object",
          "properties": {
            "correctness": { "type": "number" },
            "security": { "type": "number" },
            "performance": { "type": "number" },
            "simplicity": { "type": "number" },
            "tests": { "type": "number" },
            "errorHandling": { "type": "number" },
            "cleanup": { "type": "number" }
          }
        }
      }
    },
    "learning": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "playbookPath": { "type": "string", "default": ".cortexloop/playbook.json" },
        "global": { "type": "boolean", "default": false },
        "reflectOn": { "enum": ["direct"], "default": "direct" },
        "prune": {
          "type": "object",
          "properties": {
            "minConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
            "maxAgeDays": { "type": "integer", "minimum": 1, "default": 180 },
            "maxEntries": { "type": "integer", "minimum": 1, "default": 200 }
          }
        }
      }
    }
  }
}
