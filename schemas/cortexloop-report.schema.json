{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeCortexLoop Report",
  "type": "object",
  "required": ["version", "generatedBy", "timestamp", "preset", "scope", "mode", "scores", "findings", "summary"],
  "properties": {
    "version": { "type": "string", "const": "2.2" },
    "generatedBy": { "type": "string", "const": "cortexloop" },
    "timestamp": { "type": "string", "format": "date-time" },
    "preset": { "type": "string" },
    "scope": { "enum": ["recent", "whole"] },
    "mode": { "enum": ["report", "direct", "ci"] },
    "scores": {
      "type": "object",
      "properties": {
        "before": { "$ref": "#/definitions/scoreBlock" },
        "after": { "$ref": "#/definitions/scoreBlock" }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "summary": {
      "type": "object",
      "properties": {
        "found": { "type": "object" },
        "fixed": { "type": "object" },
        "deferred": { "type": "object" },
        "suppressed": { "type": "integer" }
      }
    }
  },
  "definitions": {
    "scoreBlock": {
      "type": "object",
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100 },
        "correctness": { "type": "number" },
        "security": { "type": "number" },
        "performance": { "type": "number" },
        "simplicity": { "type": "number" },
        "tests": { "type": "number" },
        "errorHandling": { "type": "number" },
        "cleanup": { "type": "number" }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "severity", "category", "location", "problem", "recommendation"],
      "properties": {
        "id": { "type": "string", "pattern": "^CL-[0-9]{3,}$" },
        "severity": { "enum": ["Critical", "High", "Medium", "Low", "Info"] },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "problem": { "type": "string" },
        "recommendation": { "type": "string" },
        "evidence": {
          "type": "string",
          "description": "Trigger path, measurement, test gap, static proof, or audit output. Required by the finding quality gate; echoed here so report.json stays self-describing."
        },
        "confidence": { "type": "string", "enum": ["high", "medium"] },
        "provenance": {
          "type": "object",
          "description": "Where this finding came from — populated by aggregate-findings.mjs so cross-domain duplicates stay traceable.",
          "properties": {
            "pass": { "type": "string", "description": "passKey of the expert that produced the representative finding" },
            "expert": { "type": "string" },
            "orphanId": { "type": "string", "description": "Set when the finding was added during Step 3.5 cross-validation recycle" },
            "sources": {
              "type": "array",
              "description": "Other passes/experts that flagged the same fingerprint before dedup",
              "items": {
                "type": "object",
                "properties": {
                  "pass": { "type": "string" },
                  "expert": { "type": "string" }
                }
              }
            }
          }
        },
        "autoFixable": { "enum": ["yes", "no", "needs-confirmation"] },
        "status": { "enum": ["open", "fixed", "deferred", "suppressed"] }
      }
    }
  }
}
