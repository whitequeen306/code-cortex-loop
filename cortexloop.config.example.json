{
  "$schema": "./schemas/cortexloop-config.schema.json",
  "preset": "default",
  "scope": "recent",
  "passes": {
    "review": true,
    "security": true,
    "tests": true,
    "performance": true,
    "simplicity": true,
    "errorHandling": true,
    "cleanup": true
  },
  "severityFloor": "Medium",
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".venv/**",
    "target/**",
    "**/*.min.js"
  ],
  "performance": {
    "requireBenchmark": false
  },
  "cleanup": {
    "depsOnly": false,
    "askBeforeDelete": true
  },
  "crossValidation": {
    "enabled": true
  },
  "ci": {
    "enabled": false,
    "sarif": true,
    "autoFix": false,
    "failOnCritical": true,
    "maxHigh": 0,
    "outputDir": "docs/cortexloop",
    "baseline": false
  },
  "baseline": {
    "enabled": false,
    "path": ".cortexloop/baseline.json"
  },
  "history": {
    "enabled": true,
    "path": ".cortexloop/history.json",
    "maxRuns": 100
  },
  "badge": {
    "enabled": true,
    "svgPath": ".cortexloop/health-badge.svg"
  },
  "dashboard": {
    "enabled": true,
    "htmlPath": "docs/cortexloop/report.html"
  },
  "scores": {
    "weights": {
      "correctness": 1.5,
      "security": 1.5,
      "performance": 1.0,
      "simplicity": 1.0,
      "tests": 1.0,
      "errorHandling": 1.0,
      "cleanup": 1.0
    }
  },
  "learning": {
    "enabled": true,
    "playbookPath": ".cortexloop/playbook.json",
    "global": false,
    "reflectOn": "direct",
    "queryVerifiedOnly": true,
    "tiers": {
      "newConfidence": 0.3,
      "promoteConfidence": 0.7,
      "demoteConfidence": 0.4,
      "quarantineConfidence": 0.2,
      "minVerified": 2,
      "minDistinctContexts": 2
    },
    "decay": {
      "perDay": 0.01
    },
    "outcomeWeights": {
      "external_verified": 0.2,
      "self_verified": 0.1,
      "rejected": -0.1,
      "failed": -0.4
    },
    "prune": {
      "minConfidence": 0.3,
      "maxAgeDays": 180,
      "maxEntries": 200,
      "dropQuarantined": false
    }
  }
}
