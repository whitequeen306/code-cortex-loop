{
  "$schema": "./schemas/cortexloop-config.schema.json",
  "preset": "default",
  "scope": {
    "mode": "recent",
    "mapThreshold": 100,
    "smallScopeThreshold": 50,
    "deepIndexFileThreshold": 300,
    "deepIndexTopHotspots": 15,
    "hotspotSymbolHintFiles": 8,
    "deepIndexOffer": true,
    "mapEnrichThreshold": 0.7,
    "longTailSampleCount": 20,
    "mapWeights": {
      "churn": 0.3,
      "importHub": 0.3,
      "density": 0.2,
      "patterns": 0.2
    }
  },
  "passes": {
    "review": true,
    "security": true,
    "tests": true,
    "performance": true,
    "simplicity": true,
    "errorHandling": true,
    "cleanup": true
  },
  "severityFloor": "Medium",
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".venv/**",
    "target/**",
    "**/*.min.js"
  ],
  "performance": {
    "requireBenchmark": false
  },
  "cleanup": {
    "depsOnly": false,
    "askBeforeDelete": true
  },
  "crossValidation": {
    "enabled": true
  },
  "ci": {
    "enabled": false,
    "sarif": true,
    "autoFix": false,
    "failOnCritical": true,
    "maxHigh": 0,
    "outputDir": "docs/cortexloop",
    "baseline": false
  },
  "baseline": {
    "enabled": false,
    "path": ".cortexloop/baseline.json"
  },
  "history": {
    "enabled": true,
    "path": ".cortexloop/history.json",
    "maxRuns": 100
  },
  "badge": {
    "enabled": true,
    "svgPath": ".cortexloop/health-badge.svg"
  },
  "dashboard": {
    "enabled": true,
    "htmlPath": "docs/cortexloop/report.html"
  },
  "scores": {
    "weights": {
      "correctness": 1.5,
      "security": 1.5,
      "performance": 1.0,
      "simplicity": 1.0,
      "tests": 1.0,
      "errorHandling": 1.0,
      "cleanup": 1.0
    }
  },
  "learning": {
    "enabled": true,
    "playbookPath": ".cortexloop/playbook.json",
    "global": false,
    "reflectOn": "direct",
    "queryVerifiedOnly": true,
    "prune": {
      "minConfidence": 0.3,
      "maxAgeDays": 180,
      "maxEntries": 200,
      "dropQuarantined": false
    }
  }
}
